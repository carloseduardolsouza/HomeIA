{
  "id": null,
  "uid": "mqtt-metrics",
  "title": "MQTT Metrics",
  "tags": ["mqtt"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "MQTT Endpoint Reachability",
      "targets": [
        {
          "expr": "up{job='prometheus'}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Prometheus Scrape Duration",
      "targets": [
        {
          "expr": "rate(prometheus_target_interval_length_seconds_sum[5m])",
          "refId": "B"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    }
  ]
}
